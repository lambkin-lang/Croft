package demo:ops@0.1.0;

interface collisions {
  resource pollable {
    ready: func() -> bool;
  }

  resource alpha {
    constructor();
    get: func() -> option<string>;
    subscribe: func() -> pollable;
  }

  resource beta {
    constructor();
    get: func() -> option<u32>;
    subscribe: func() -> pollable;
  }
}
