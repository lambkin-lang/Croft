package lambkin:host-gpu2d@0.1.0;

interface types {
  type utf8 = list<u8>;

  flags capabilities {
    text,
    transform,
    clip,
    present,
  }

  type surface-result = result<surface, string>;
  type status = result<_, string>;
  type capabilities-result = result<capabilities, string>;
  type measure-result = result<f32, string>;

  @croft-lower-group(command)
  resource surface {
    capabilities: static func() -> capabilities-result;
    open: static func() -> surface-result;
    drop: func() -> status;
    begin-frame: func(width: u32, height: u32) -> status;
    clear: func(color-rgba: u32) -> status;
    draw-rect: func(x: f32, y: f32, w: f32, h: f32, color-rgba: u32) -> status;
    draw-text: func(x: f32, y: f32, utf8: utf8, font-size: f32, color-rgba: u32) -> status;
    measure-text: func(utf8: utf8, font-size: f32) -> measure-result;
    save: func() -> status;
    restore: func() -> status;
    translate: func(dx: f32, dy: f32) -> status;
    scale: func(sx: f32, sy: f32) -> status;
    clip-rect: func(x: f32, y: f32, w: f32, h: f32) -> status;
    end-frame: func() -> status;
  }
}

world host-gpu2d {
  export types;
}
