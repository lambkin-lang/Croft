package lambkin:host-gpu2d@0.1.0;

interface types {
  type utf8 = list<u8>;

  resource surface;

  flags capabilities {
    text,
    transform,
    clip,
    present,
  }

  record capabilities-query {}

  record open {}

  record surface-op {
    surface: surface,
  }

  record begin-frame {
    surface: surface,
    width: u32,
    height: u32,
  }

  record clear {
    surface: surface,
    color-rgba: u32,
  }

  record draw-rect {
    surface: surface,
    x: f32,
    y: f32,
    w: f32,
    h: f32,
    color-rgba: u32,
  }

  record draw-text {
    surface: surface,
    x: f32,
    y: f32,
    utf8: utf8,
    font-size: f32,
    color-rgba: u32,
  }

  record measure-text {
    surface: surface,
    utf8: utf8,
    font-size: f32,
  }

  record translate {
    surface: surface,
    dx: f32,
    dy: f32,
  }

  record scale {
    surface: surface,
    sx: f32,
    sy: f32,
  }

  record clip-rect {
    surface: surface,
    x: f32,
    y: f32,
    w: f32,
    h: f32,
  }

  type surface-result = result<surface, string>;
  type status = result<_, string>;
  type capabilities-result = result<capabilities, string>;
  type measure-result = result<f32, string>;

  capabilities: func(query: capabilities-query) -> capabilities-result;
  open: func(request: open) -> surface-result;
  drop: func(op: surface-op) -> status;
  begin-frame: func(request: begin-frame) -> status;
  clear: func(request: clear) -> status;
  draw-rect: func(request: draw-rect) -> status;
  draw-text: func(request: draw-text) -> status;
  measure-text: func(request: measure-text) -> measure-result;
  save: func(op: surface-op) -> status;
  restore: func(op: surface-op) -> status;
  translate: func(request: translate) -> status;
  scale: func(request: scale) -> status;
  clip-rect: func(request: clip-rect) -> status;
  end-frame: func(op: surface-op) -> status;
}

world host-gpu2d {
  export types;
}
