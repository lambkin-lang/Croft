package lambkin:host-popup-menu@0.1.0;

interface types {
  record show-at {
    x-milli: s32,
    y-milli: s32,
  }

  record popup-item {
    action-id: s32,
    label: list<u8>,
    enabled: bool,
    separator: bool,
  }

  type status = result<_, string>;
  type action-result = result<option<s32>, string>;

  begin-popup: func() -> status;
  add-item: func(item: popup-item) -> status;
  show-at: func(at: show-at) -> action-result;
}

world host-popup-menu {
  export types;
}
