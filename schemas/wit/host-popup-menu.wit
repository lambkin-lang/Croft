package lambkin:host-popup-menu@0.1.0;

interface types {
  record begin-popup {}

  record show-at {
    x-milli: s32,
    y-milli: s32,
  }

  record popup-item {
    action-id: s32,
    label: list<u8>,
    enabled: bool,
    separator: bool,
  }

  type status = result<_, string>;
  type action-result = result<option<s32>, string>;

  variant command {
    begin-popup(begin-popup),
    add-item(popup-item),
    show-at(show-at),
  }

  variant reply {
    status(status),
    action(action-result),
  }
}

world host-popup-menu {
  export types;
}
