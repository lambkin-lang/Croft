package lambkin:host-a11y@0.1.0;

interface types {
  resource node;

  enum role {
    unknown,
    window,
    group,
    text,
    button,
  }

  record open {}

  record close {}

  record bounds {
    x: f32,
    y: f32,
    width: f32,
    height: f32,
  }

  record create-node {
    role: role,
    bounds: bounds,
    label: option<list<u8>>,
  }

  record add-child {
    parent: option<node>,
    child: node,
  }

  record update-frame {
    node: node,
    bounds: bounds,
  }

  record destroy-node {
    node: node,
  }

  type node-result = result<node, string>;
  type status = result<_, string>;

  open: func(request: open) -> status;
  close: func(request: close) -> status;
  create-node: func(request: create-node) -> node-result;
  add-child: func(request: add-child) -> status;
  update-frame: func(request: update-frame) -> status;
  destroy-node: func(request: destroy-node) -> status;
}

world host-a11y {
  export types;
}
